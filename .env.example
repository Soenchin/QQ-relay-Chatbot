# ─── DeepSeek API（直调模式必填） ───
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ─── SnowLuma / NapCat WebSocket ───
NAPCAT_WS_URL=ws://127.0.0.1:3001
NAPCAT_TOKEN=your-token-here

# ─── 机器人名称（显示在日志/管道/WebUI 中） ───
BOT_NAME=QQ Bot

# ─── 最高权限QQ号配置 ───
MASTER_QQ=your-qq-number

# ─── 群模式分流 ───
# GROUP_MODE: JSON 字典，key=群号(字符串)，value="direct"(直调) 或 "pipe"(管道)
# 不在字典里的群走 FALLBACK_MODE（可选值: direct / pipe）
# 示例: GROUP_MODE={"123456789":"direct","987654321":"pipe"}
GROUP_MODE=
FALLBACK_MODE=direct

# ─── Claude CLI 路径（pipe 模式用） ───
# CLAUDE_CMD=claude

# ─── 数据目录（默认为项目目录下的 memory/） ───
# MEM_DIR=./memory

# ─── 图床端口 ───
# MEME_SERVER_PORT=8801
